# MongoDB Atlas connection string
# Copy file này thành .env.local rồi điền giá trị thật.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/doctor-app?retryWrites=true&w=majority"

# Khoá ký phiên đăng nhập (JWT) - dùng chuỗi ngẫu nhiên dài (>= 32 ký tự).
SESSION_SECRET="thay-bang-chuoi-ngau-nhien-dai-32-ky-tu"

# Cloudinary (upload file ghi âm)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
